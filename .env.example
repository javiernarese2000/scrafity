# =====================================================================
# ENTORNOS
# El `.env` de la raíz = entorno de DESARROLLO (apunta al proyecto Supabase
# de dev). Producción NO usa este archivo: sus variables viven en el panel
# de Railway. Así, trabajar local nunca toca los datos del cliente.
# Al hacer un release, las migraciones se aplican aparte a prod.
# =====================================================================

# --- Base de datos (Supabase Postgres — proyecto de DEV) ---
# Connection pooler (para la app)
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true"
# Conexión directa (para migraciones de Drizzle)
DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# --- Supabase Auth / Storage ---
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# --- Proveedores de IA ---
DEEPSEEK_API_KEY=""
ANTHROPIC_API_KEY=""

# --- Ingesta de contenido ---
FIRECRAWL_API_KEY=""

# --- Inngest (jobs) ---
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""
