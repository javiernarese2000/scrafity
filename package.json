{
  "name": "scrapify",
  "private": true,
  "version": "0.1.0",
  "description": "Scrapify — agregador y reescritor de noticias con IA",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @scrapify/db db:generate",
    "db:migrate": "pnpm --filter @scrapify/db db:migrate",
    "db:push": "pnpm --filter @scrapify/db db:push"
  },
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "turbo": "^2.9.18",
    "typescript": "^6.0.3"
  }
}
